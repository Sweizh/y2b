name = "y2b"
main = "src/index.ts"
compatibility_date = "2024-12-01"

# 静态资源目录：部署时通过 [site] 配置打包进 Worker
# 参考 https://developers.cloudflare.com/workers/static-assets/
[site]
bucket = "./public"

# KV 命名空间绑定
# id 通过环境变量引用(${VAR} 语法),避免 fork 仓库时 KV id 被覆盖
# 本地开发:在 .dev.vars 文件中设置 CLOUDFLARE_KV_ID 和 CLOUDFLARE_KV_PREVIEW_ID
# Cloudflare Dashboard Git 部署:在 Worker → Settings → Variables 中配置
# 本地开发时 wrangler 会自动创建本地 KV 模拟,未设置环境变量时会回退到本地模拟
[[kv_namespaces]]
binding = "YT2BILI_KV"
id = "${CLOUDFLARE_KV_ID}"
preview_id = "${CLOUDFLARE_KV_PREVIEW_ID}"

# 加密主密钥：执行 `wrangler secret put ENCRYPTION_KEY`，输入 32 字节随机字符串
# 用于 AES-GCM 加密 KV 中存储的敏感字段（B 站 Cookie、API Key 等）
# 本地开发可用 .dev.vars 文件注入 ENCRYPTION_KEY，例如：
#   ENCRYPTION_KEY="dev-only-32-bytes-or-more-string"

# 本地开发环境变量（仅 wrangler dev 使用）
[vars]
# 此处不写敏感信息；本地开发请在 .dev.vars 写
