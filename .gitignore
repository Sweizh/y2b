# 依赖
node_modules/

# 构建产物
/dist/
.wrangler/

# 前端构建产物(由 npm run build:frontend 生成,不入库;仅保留 .gitkeep 占位)
public/css/dist/*
!public/css/dist/.gitkeep
public/js/dist/*
!public/js/dist/.gitkeep

# Python 缓存
__pycache__/
*.pyc

# 本地开发环境变量(含敏感密钥,不入库)
.dev.vars

# 本地 wrangler 配置(由 scripts/setup.mjs 从 wrangler.toml.example 生成,不入库)
# 避免 fork 仓库 sync 上游时覆盖用户特定的 KV namespace ID
wrangler.toml

# 临时/工作产物
*.log
.DS_Store
y2b_blog.html
y2b_blog.txt

# 设计稿原始上传(工作产物,不入库)
.uploads/

# Trae spec 元数据(本地工作流,不入库)
.trae/
